# Frontend Dashboard Environment Configuration
# Copy this file to .env.local and update values for your environment

# ============================================================================
# Backend Service URLs (used by Next.js rewrites)
# These should point to your running backend services
# ============================================================================

# Auth Service URL (Go/Fiber backend)
# Default: http://localhost:3000 for local development
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3000

# Resource Allocator Service URL (Node.js/Express backend)
# Default: http://localhost:5000 for local development
NEXT_PUBLIC_RESOURCE_ALLOCATOR_URL=http://localhost:5000

# Socket.IO URL (for real-time logs, optional)
# If not set, falls back to NEXT_PUBLIC_RESOURCE_ALLOCATOR_URL
# Example for production: wss://api.yourdomain.com
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# ============================================================================
# Next.js Configuration
# ============================================================================

# Development port (optional, defaults to 3001 in package.json)
# PORT=3001

# Node environment
NODE_ENV=development
