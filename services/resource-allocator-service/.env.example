# Resource Allocator Service Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# Server Configuration
# ============================================================================

# Port the service runs on (default: 5000)
PORT=5000

# Node environment (development | production)
# In production, missing required vars will throw errors
NODE_ENV=development

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Example for local: postgresql://postgres:postgres@localhost:5432/resource_allocator?schema=public
# Example for Neon DB: postgresql://user:password@neon-host.neon.tech/resource_allocator?sslmode=require
DATABASE_URL=postgresql://username:password@localhost:5432/resource_allocator?schema=public

# ============================================================================
# Authentication / Security
# ============================================================================

# JWT Secret (must match the auth-service JWT_SECRET)
# IMPORTANT: Change this in production! Use a strong random string.
# In production (NODE_ENV=production), this is REQUIRED and has no default.
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Origins (comma-separated list of allowed origins)
# Use "*" to allow all (not recommended for production)
# Example: CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGIN=*

# ============================================================================
# Prometheus / Monitoring
# ============================================================================

# Prometheus query URL
# Default in development: http://localhost:9090/api/v1/query
# In production (NODE_ENV=production), this is REQUIRED and has no default.
# Example for production: https://prometheus.yourdomain.com/api/v1/query
PROM_URL=http://localhost:9090/api/v1/query

# ============================================================================
# Kubernetes / Ingress Configuration
# ============================================================================

# Ingress IP for generated pod URLs
# For local KIND clusters: 127.0.0.1 (default)
# For cloud deployments: Your load balancer IP or domain
# INGRESS_IP=127.0.0.1

# Kubernetes namespace for ingress controller (default: ingress-nginx)
# K8S_INGRESS_NAMESPACE=ingress-nginx

# Ingress controller service name (default: ingress-nginx-controller)
# K8S_INGRESS_SERVICE=ingress-nginx-controller

# ============================================================================
# Optional / Advanced
# ============================================================================

# Kafka broker (if using Kafka for event streaming)
# KAFKA_BROKER=localhost:9092

# Log level (debug | info | warn | error)
# LOG_LEVEL=info
